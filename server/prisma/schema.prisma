// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Keyword {
  id        String    @id @default(uuid())
  text      String    @unique
  category  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  hotspots  Hotspot[]
  runs      CrawlRun[]
}

model Hotspot {
  id              String    @id @default(uuid())
  title           String
  content         String
  url             String
  source          String    // twitter, bing, google
  sourceId        String?   // 原始推文ID等
  isReal          Boolean   @default(true)
  relevance       Int       @default(0)
  relevanceReason String?   // AI 分析相关性的理由
  keywordMentioned Boolean?  // 内容中是否直接提及了关键词
  importance      String    @default("low")
  summary         String?
  viewCount       Int?
  likeCount       Int?
  retweetCount    Int?
  replyCount      Int?      // 回复数
  commentCount    Int?      // 评论数
  quoteCount      Int?      // 引用/转引数
  danmakuCount    Int?      // 弹幕数 (Bilibili)
  authorName      String?   // 作者名称
  authorUsername  String?   // 作者用户名
  authorAvatar    String?   // 作者头像
  authorFollowers Int?      // 作者粉丝数
  authorVerified  Boolean?  // 作者是否认证
  publishedAt      DateTime?
  tenderType       String?   // BIM招采分类：设计BIM、全过程BIM等
  tenderRegion     String?   // 招采地区
  tenderCity       String?   // 城市/站点
  tenderUnit       String?   // 招标/采购/建设单位
  tenderBudgetWan  Float?    // 预算金额，单位：万元
  tenderDeadline   DateTime? // 投标/文件截止时间
  tenderNoticeType String?   // 公告类型
  tenderPlatform   String?   // 平台名称
  tenderProjectCode String?   // 项目编号/招标编号/采购编号
  tenderContact     String?   // 联系人
  tenderPhone       String?   // 联系电话
  tenderEmail       String?   // 联系邮箱
  tenderBidOpenTime DateTime? // 开标时间
  tenderDocDeadline DateTime? // 招标/采购文件获取截止时间
  tenderServiceScope String?  // BIM服务范围/采购内容
  tenderQualification String? // 资质/资格要求
  tenderAddress      String?  // 开标/递交/项目地址
  tenderDetailSource String?  // detail-api/firecrawl/rule 等
  tenderDetailExtractedAt DateTime? // 详情字段提取时间
  createdAt        DateTime  @default(now())
  keywordId       String?
  keyword         Keyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([url, source])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // hotspot, alert
  title     String
  content   String
  isRead    Boolean  @default(false)
  hotspotId String?
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model CrawlRun {
  id               String        @id @default(uuid())
  triggerType      String        // manual, scheduled
  status           String        @default("running") // running, completed, failed
  keywordText      String?
  keywordId        String?
  searchQueries    String?       // JSON array
  totalRaw         Int           @default(0)
  totalUnique      Int           @default(0)
  totalFresh       Int           @default(0)
  totalSaved       Int           @default(0)
  totalFiltered    Int           @default(0)
  errorMessage     String?
  startedAt        DateTime      @default(now())
  completedAt      DateTime?
  keyword          Keyword?      @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  sourceProbes     SourceProbe[]

  @@index([startedAt])
  @@index([status])
}

model AiAnalysisLog {
  id           String   @id @default(uuid())
  runId        String?
  hotspotId    String?
  source       String?
  keywordText  String?
  title        String?
  url          String?
  provider     String   @default("unknown") // openclaw/openrouter/rule
  status       String   @default("success") // success/fallback/error
  fallbackUsed Boolean  @default(false)
  attemptCount Int      @default(0)
  elapsedMs    Int      @default(0)
  relevance    Int?
  importance   String?
  reason       String?
  errorMessage String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([provider, createdAt])
  @@index([runId])
  @@index([hotspotId])
}

model SourceProbe {
  id           String    @id @default(uuid())
  runId        String
  sourceId     String
  sourceName   String
  queryText    String?
  enabled      Boolean   @default(true)
  ok           Boolean   @default(false)
  resultCount  Int       @default(0)
  elapsedMs    Int       @default(0)
  sampleTitle  String?
  sampleUrl    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  run          CrawlRun  @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([sourceId, createdAt])
}

model DailySource {
  id         String         @id
  name       String
  homepage   String
  listUrl    String
  sourceType String
  isActive   Boolean        @default(true)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  articles   DailyArticle[]
}

model DailyKeyword {
  id          String                 @id @default(uuid())
  label       String                 @unique
  slug        String                 @unique
  aliasesJson String?
  category    String?
  sortOrder   Int                    @default(0)
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  hits        DailyArticleKeywordHit[]
}

model DailyReport {
  id               String         @id @default(uuid())
  reportDate       DateTime       @unique
  title            String
  intro            String
  executiveSummary String
  sectionsJson     String
  status           String         @default("completed")
  sourceCount      Int            @default(0)
  articleCount     Int            @default(0)
  keywordStatsJson String
  generatedAt      DateTime       @default(now())
  createdAt        DateTime       @default(now())
  articles         DailyArticle[]
  runs             DailyRun[]
}

model DailyArticle {
  id                String                 @id @default(uuid())
  sourceId          String
  reportId          String
  reportDate        DateTime
  title             String
  excerpt           String?
  summary           String?
  url               String
  publishedAt       DateTime?
  category          String?
  fetchStatus       String                 @default("fetched")
  contentHash       String
  keywordHitPreview String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  source            DailySource            @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  report            DailyReport            @relation(fields: [reportId], references: [id], onDelete: Cascade)
  keywordHits       DailyArticleKeywordHit[]

  @@unique([sourceId, url, reportDate])
  @@index([reportDate])
  @@index([sourceId, reportDate])
  @@index([reportId])
}

model DailyArticleKeywordHit {
  id           String       @id @default(uuid())
  articleId    String
  keywordId    String
  matchedText  String
  matchCount   Int          @default(1)
  hitFieldsJson String
  createdAt    DateTime     @default(now())
  article      DailyArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  keyword      DailyKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)

  @@unique([articleId, keywordId])
  @@index([keywordId, createdAt])
  @@index([articleId])
}

model DailyRun {
  id                String       @id @default(uuid())
  triggerType       String
  status            String       @default("running")
  sourceCount       Int          @default(0)
  articleCount      Int          @default(0)
  reportId          String?
  sourceSummaryJson String?
  errorMessage      String?
  startedAt         DateTime     @default(now())
  completedAt       DateTime?
  report            DailyReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([startedAt])
  @@index([status])
}
