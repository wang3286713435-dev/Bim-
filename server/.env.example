# 数据库
DATABASE_URL="file:./dev.db"

# 服务器配置
PORT=3001
CLIENT_URL=http://localhost:5173

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-v3.2

# AI Provider: openrouter | openclaw
AI_PROVIDER=openrouter

# OpenClaw agent bridge
OPENCLAW_AGENT_ID=bim-tender
OPENCLAW_BIN=openclaw
OPENCLAW_TIMEOUT_MS=180000

# Twitter API (twitterapi.io)
TWITTER_API_KEY=your_twitter_api_key_here

# Firecrawl
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_MS=30000
FIRECRAWL_CACHE_TTL_MS=86400000
FIRECRAWL_CACHE_FILE=.cache/firecrawl-cache.json

# 招采扫描控制
TENDER_SOURCES=szggzy,szygcgpt,guangdong,gzebpubservice
TENDER_MAX_AGE_DAYS=365
TENDER_SOURCE_RESULT_LIMIT=8
TENDER_RESULTS_PER_KEYWORD=8
TENDER_QUERY_VARIANTS_PER_KEYWORD=2
TENDER_SOURCE_RETRY_COUNT=2
TENDER_SOURCE_RETRY_DELAY_MS=1200
TENDER_SOURCE_CIRCUIT_BREAKER_THRESHOLD=3
TENDER_SOURCE_CIRCUIT_BREAKER_COOLDOWN_MS=300000
GUANGDONG_MAX_PAGES=2

# 邮件通知 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=notify_to@example.com

# 飞书通知 (可选)
# 群机器人 webhook：新增高价值公告时推送到飞书群
FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace_me
FEISHU_BOT_SECRET=

# 飞书多维表格 (可选)
# 仅当你希望把结构化字段落到多维表格时填写
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_BITABLE_TABLE_ID=your_bitable_table_id
